<?xml version="1.0" encoding="utf-8"?>
<!--
  Intentionally insecure IIS web.config for webconf-audit demo/local_admin.
  This file exercises the full IIS local rule pack (20 rules).
-->
<configuration>
    <system.webServer>
        <!-- iis.directory_browse_enabled -->
        <directoryBrowse enabled="true" />

        <!-- iis.http_errors_detailed -->
        <httpErrors errorMode="Detailed" />

        <!-- iis.ssl_not_required (sslFlags="None") -->
        <security>
            <access sslFlags="None" />
            <authentication>
                <!-- iis.anonymous_auth_enabled (anon + basic combination) -->
                <anonymousAuthentication enabled="true" />
                <basicAuthentication enabled="true" />
            </authentication>
            <requestFiltering
                allowDoubleEscaping="true"
                allowHighBitCharacters="true">
                <!-- iis.max_allowed_content_length_missing (no maxAllowedContentLength) -->
                <requestLimits maxUrl="8192" />
            </requestFiltering>
        </security>

        <!-- iis.logging_not_configured: httpLogging with dontLog -->
        <httpLogging dontLog="true" />

        <httpProtocol>
            <customHeaders>
                <!-- iis.custom_headers_expose_server (X-Powered-By + X-AspNetMvc-Version) -->
                <add name="X-Powered-By" value="ASP.NET" />
                <add name="X-AspNetMvc-Version" value="5.2" />
                <!-- iis.missing_hsts_header: no Strict-Transport-Security -->
            </customHeaders>
        </httpProtocol>

        <!-- Classic ASP settings -->
        <asp scriptErrorSentToBrowser="true" />

        <modules>
            <!-- iis.webdav_module_enabled -->
            <add name="WebDAVModule" />
        </modules>

        <handlers>
            <!-- iis.cgi_handler_enabled -->
            <add name="CGI-exe" path="*.exe" verb="*"
                 modules="CgiModule" resourceType="File" />
        </handlers>
    </system.webServer>

    <system.web>
        <!-- iis.custom_errors_off -->
        <customErrors mode="Off" />

        <!-- iis.compilation_debug_enabled -->
        <compilation debug="true" />

        <!-- iis.trace_enabled -->
        <trace enabled="true" />

        <!-- iis.http_runtime_version_header_enabled -->
        <httpRuntime enableVersionHeader="true" />

        <authentication>
            <!-- iis.forms_auth_require_ssl_missing -->
            <forms requireSSL="false" loginUrl="/login" />
        </authentication>

        <!-- iis.session_state_cookieless -->
        <sessionState cookieless="UseUri" />
    </system.web>

    <!-- Location override: directoryBrowse disabled at /secure -->
    <location path="secure">
        <system.webServer>
            <directoryBrowse enabled="false" />
        </system.webServer>
    </location>

    <!-- Location override: SSL required at /api, but only Ssl (no Ssl128) -->
    <location path="api">
        <system.webServer>
            <security>
                <!-- iis.ssl_weak_cipher_strength (Ssl without Ssl128) -->
                <access sslFlags="Ssl" />
            </security>
        </system.webServer>
    </location>
</configuration>

<?xml version="1.0" encoding="utf-8"?>
<!--
  Minimal machine.config for webconf-audit demo/local_admin.
  Exercises the machine.config -> applicationHost.config -> web.config
  three-level merge chain (block C).
-->
<configuration>
    <system.web>
        <!-- compilation debug=true at machine level should propagate -->
        <compilation debug="true" />
        <!-- httpRuntime version header at machine level -->
        <httpRuntime enableVersionHeader="true" />
    </system.web>
</configuration>
